/target
**/*.rs.bk
# Cargo.lock is committed — swarmx ships binaries, and locked deps make
# `cargo build` reproducible across machines. (Skipped only for pure-library
# crates, which this workspace isn't.)

# frontend
/web/node_modules
/web/dist
/web/.vite
/web/tsconfig.tsbuildinfo

# data
/data
/.swarmx
/.secrets/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# editor
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json

# logs
*.log

# local scratch (screenshots, manual repro, etc.)
/.tmp
/.tmp-screenshots
/.swarmx-ui-screens

# per-user MCP / Claude Code state (different on every machine)
/.mcp.json
/.claude/
.tmp-ui-audit/
