{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "flockmux",
  "mainBinaryName": "flockmux-tauri",
  "version": "0.1.0",
  "identifier": "com.flockmux.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "flockmux",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/flockmux-server",
      "binaries/flockmux-shim",
      "binaries/flockmux-mcp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDOEIwMDI1OEI5OTFBRjkKUldUNUdwbUxKUUNMSEVPcmM1d3I1TE1iQW9TMGFHQjFEaHFFamNrUkhtVVg1aGZqTDVQYnI5ZEYK",
      "endpoints": [
        "https://github.com/curdx/flockmux-core/releases/latest/download/latest.json"
      ]
    }
  }
}
