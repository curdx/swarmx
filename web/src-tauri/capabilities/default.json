{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default flockmux desktop permissions (sidecar spawn of bundled flockmux-server)",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/flockmux-server",
          "sidecar": true
        }
      ]
    },
    "dialog:default",
    "updater:default",
    "process:default",
    "notification:default",
    "core:window:allow-start-dragging"
  ]
}
